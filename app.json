{
  "expo": {
    "name": "مسجدي - Masjidie",
    "slug": "masjidie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logoSpaced.png",
    "scheme": "masjidie",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.masjidie2.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B7A4E",
        "foregroundImage": "./assets/logoSpaced.png",
        "backgroundImage": "./assets/logoSpaced.png",
        "monochromeImage": "./assets/logoSpaced.png"
      },
      "package": "com.masjidie2.app",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logoSpaced.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logoSpaced.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f9f9f9",
          "dark": {
            "backgroundColor": "#f9f9f9"
          }
        }
      ],
      "expo-localization",
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/adahnsounda.mp3",
            "./assets/sounds/adahnsoundfajr.mp3"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "95b30dd5-c758-47bd-a00d-0dcca905f1f6"
      },
      "router": {}
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d23c4e91-a110-488d-97c8-738b656e6862"
    }
  }
}
